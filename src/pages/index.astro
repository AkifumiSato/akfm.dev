---
import Layout from "../layouts/Layout.astro";
---

<Layout title="akfm.dev">
  <div class="container">
    <div class="contents">
      <main class="main">
        <h1 class="title"># akfm.dev</h1>
        <section class="section">
          <h2 class="sectionTitle">## Name</h2>
          <p>Akifumi Sato.</p>
        </section>
        <section class="section">
          <h2 class="sectionTitle">## About</h2>
          <p>Web application developer interested in Rust / Typescript.</p>
        </section>
        <section class="section">
          <h2 class="sectionTitle">## Links</h2>
          <ul>
            <li>
              <a href="https://github.com/AkifumiSato">github</a>
            </li>
            <li>
              <a href="https://zenn.dev/akfm">zenn.dev</a>
            </li>
            <li>
              <a href="https://twitter.com/akfm_sato">twitter</a>
            </li>
          </ul>
        </section>
      </main>

      <footer class="footer">
        <p class="copyright">
          ©︎akfm.dev 2022. Using&nbsp;
          <a
            href="https://www.google.com/intl/ja/policies/privacy/partners/"
            target="_blank"
            rel="noreferrer"
          >
            Google Analytics
          </a>
        </p>
      </footer>
    </div>
  </div>
</Layout>

<style>
  .container {
    display: flex;
    align-items: center;
    flex-direction: column;
  }

  .contents {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 100vh;
    width: 660px;
  }

  .main {
    padding: 50px 0;
    display: flex;
    flex-direction: column;
    row-gap: 50px;
  }

  .title {
    font-size: 30px;
  }

  .section {
    display: flex;
    flex-direction: column;
    row-gap: 20px;
  }

  .sectionTitle {
    font-size: 25px;
  }

  .footer {
    display: flex;
    align-items: center;
    height: 60px;
  }

  .copyright {
    color: #adadad;
    font-size: 14px;
  }
</style>
